# ─── LLM Provider (priority: GROQ → GEMINI → ANTHROPIC) ─────────────────────

# Groq — free tier, no billing needed (https://console.groq.com)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant   # default

# Gemini — free tier via Google AI Studio (https://aistudio.google.com/apikey)
# Note: key must be from a project WITHOUT billing enabled to use free quota
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic — used only if neither Groq nor Gemini key is set
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Voyage AI (embeddings) ───────────────────────────────────────────────────
VOYAGE_API_KEY=

# ─── Walrus ──────────────────────────────────────────────────────────────────
WALRUS_NETWORK=testnet
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Mainnet (swap for demo day)
# WALRUS_PUBLISHER_URL=https://publisher.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus.space

# ─── Sui ─────────────────────────────────────────────────────────────────────
SUI_NETWORK=testnet
MNEMOS_REGISTRY_OBJECT_ID=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
